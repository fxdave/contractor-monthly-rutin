{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "references": [
    { "path": "packages/nav" },
    { "path": "packages/clockify" },
    { "path": "packages/otp" },
    { "path": "apps/tui" }
  ],
  "include": []
}
