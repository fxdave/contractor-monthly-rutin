NAV_MODE=testing # for testing online-szamla environment. Possible values: production, testing

# NAV technical user credentials
NAV_TECHNICAL_USER_NAME=
NAV_TECHNICAL_USER_PASS=

# Signing key (SHA3-512 request signature)
NAV_XML_SIGNING_KEY=

# Exchange key (AES-128-ECB, 16 bytes UTF-8)
NAV_XML_EXCHANGE_KEY=

# Your 8-digit NAV taxpayer ID (without vatCode/countyCode)
NAV_TAX_NUMBER=

# Software registration (optional — defaults shown)
# NAV_SOFTWARE_ID=HU{NAV_TAX_NUMBER}-INV-001
# NAV_SOFTWARE_NAME=Invoice Manager
# NAV_SOFTWARE_VERSION=1.0

# Developer info (registered with NAV)
NAV_DEV_NAME=
NAV_DEV_CONTACT=
NAV_DEV_COUNTRY=HU
NAV_DEV_TAX_NUM=

# Supplier extras shown on rendered invoice (optional)
NAV_SUPPLIER_EU_VAT=
NAV_SUPPLIER_BANK_ACCOUNT=
NAV_SUPPLIER_IBAN=
NAV_SUPPLIER_BANK_NAME=
NAV_SUPPLIER_SWIFT=

# Clockify integration (optional — needed for TUI Clockify menu)
# CLOCKIFY_API_KEY=

# OTP Bank (optional — needed for TUI OTP menu)
# OTP_DOWNLOAD_DIR=
